PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/poseidonjs
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-different-from-above
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN_FRONTEND=http://localhost:3000
CORS_ORIGIN_ADMIN=http://localhost:3001

# Cloudinary Configuration (for image uploads)
# Get your credentials from: https://cloudinary.com/
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email Configuration (Gmail)
# For Gmail: Enable 2FA and create an App Password
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM_NAME=PoseidonJS Admin

# Admin / dashboard base URL (password reset links, etc.)
FRONTEND_URL=http://localhost:3001

# Shop URL — verification emails MUST use this (not FRONTEND_URL). Default: http://localhost:3000
STOREFRONT_URL=http://localhost:3000

# Rate Limiting (adjust for production)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Anthropic Claude (AI assistant, summaries, vendor tools)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
# Optional override (default: claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
