# .npmignore - Files to exclude when publishing to npm

# Source control
.git/
.gitignore

# Development files
.vscode/
.idea/

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db

# Don't publish the templates' node_modules if they exist
templates/*/node_modules/
templates/*/.next/
templates/*/.env
templates/*/.env.local
templates/*/package-lock.json
templates/*/yarn.lock
templates/*/pnpm-lock.yaml

# Test files
test/
tests/
*.test.js
*.spec.js

# Documentation that's not needed in package
docs/
examples/
SYSTEM_CHECK_REPORT.md
ALL_GOOD_FINAL.md
UPDATE_v1.0.2.md
create-admin.sh
